{
  "languageserver": {
    "golang": {
      "command": "gopls",
      "rootPatterns": ["go.mod"],
      "filetypes": ["go"]
    },
    "terraform": {
      "command": "terraform-lsp",
      "filetypes": ["terraform", "tf"],
      "initializationOptions": {},
      "settings": {}
    },
    "bash": {
      "command": "bash-language-server",
      "args": ["start"],
      "filetypes": ["sh"],
      "ignoredRootPaths": ["~"]
    },
    "groovy": {
      "command": "java",
      "args" : ["-jar", "/Users/simon.harvey/.config/nvim-nightly/plugged/groovy-language-server/build/libs/groovy-language-server-all.jar "],
      "filetypes": ["groovy"]
    }
  },

  "yaml.schemaStore.enable": true,
  "yaml.schemas": {
    "kubernetes": "/*.yaml"
  },

  "http.proxyCA": "/Users/simon.harvey/Zscaler/ZscalerRootCertificate-2048-SHA256.crt",

  // explorer
  "explorer.width": 30,
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "explorer.keyMappings.global": {
    "<cr>": ["expandable?", "expand", "open"],
    "v": "open:vsplit"
  }
}

